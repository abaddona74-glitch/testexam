# Example Environment Variables
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# MongoDB Connection
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority"

# Development Mode (set to false in production)
NEXT_PUBLIC_DEV_MODE=false

# Google AI API Key (Get from Google Cloud Console)
GOOGLE_API_KEY=your_google_api_key_here

# Yandex SmartCaptcha (Get from https://yandex.cloud/dev/smartcaptcha)
NEXT_PUBLIC_YCAPTCHA_SITEKEY=your_yandex_captcha_site_key
YCAPTCHA_SECRET=your_yandex_captcha_secret_key

# Test Upload Configuration
TEST_UPLOAD_MODE=community
NEXT_PUBLIC_TEST_UPLOAD_MODE=community
ALLOW_GODMODE_UPLOAD=0

# Admin Panel Credentials (Generate strong passwords!)
# Generate with: openssl rand -base64 32
ADMIN_SECRET=your_strong_admin_password_min_32_chars
ADMIN_SESSION_SECRET=your_session_secret_min_64_chars

# Vercel Blob Storage (Get from Vercel dashboard)
BLOB_STORE_ID=your_blob_store_id
BLOB_READ_WRITE_TOKEN=your_blob_token

# SMS Provider (optional - for OTP phone verification)
HTTPSMS_API_KEY=your_sms_api_key
HTTPSMS_FROM=+998XXXXXXXXX

# Email (SMTP) Provider (optional - for OTP email verification)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=your_email@gmail.com

# OTP Secret
OTP_SECRET=your_otp_secret_key
